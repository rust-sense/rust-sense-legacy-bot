{
    "name": "rustplusplus",
    "version": "1.30.1",
    "description": "A NodeJS Discord Bot that uses the rustplus.js library to utilize the power of the Rust+ Companion App with additional Quality-of-Life features.",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "proto:gen": "pbjs -t static-module -w es6 --es6 src/lib/fcm/proto/mcs.proto src/lib/fcm/proto/checkin.proto src/lib/fcm/proto/android_checkin.proto -o src/lib/fcm/proto/mcs_pb.js && pbts -o src/lib/fcm/proto/mcs_pb.d.ts src/lib/fcm/proto/mcs_pb.js && pbjs -t static-module -w es6 --es6 src/lib/rustplus/rustplus.proto -o src/lib/rustplus/rustplus_pb.js && pbts -o src/lib/rustplus/rustplus_pb.d.ts src/lib/rustplus/rustplus_pb.js",
        "build": "pnpm run proto:gen && tsc",
        "test": "tsc --noEmit",
        "dev": "pnpm run proto:gen && tsx watch src/index.ts",
        "format": "biome format --write",
        "lint": "biome lint"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/rust-sense/bot.git"
    },
    "author": "jamezrin",
    "bugs": {
        "url": "https://github.com/rust-sense/bot/issues"
    },
    "homepage": "https://github.com/rust-sense/bot",
    "dependencies": {
        "@discordjs/builders": "^1.14.1",
        "@discordjs/rest": "^2.6.1",
        "@discordjs/voice": "^0.19.2",
        "@formatjs/intl": "^4.1.8",
        "awilix": "^13.0.3",
        "axios": "^1.15.2",
        "colors": "^1.4.0",
        "discord-api-types": "^0.38.47",
        "discord.js": "^14.26.3",
        "ffmpeg-static": "^5.3.0",
        "gm": "^1.25.1",
        "intl-messageformat": "^11.2.3",
        "http_ece": "^1.2.0",
        "jimp": "^1.6.1",
        "long": "^5.3.0",
        "lodash": "^4.18.1",
        "protobufjs": "^7.5.5",
        "sodium-native": "^5.1.0",
        "translate": "^3.0.1",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "ws": "^8.18.0"
    },
    "resolutions": {
        "jpeg-js": "0.4.4",
        "protobufjs": "7.5.5"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.13",
        "@types/ws": "^8.5.14",
        "protobufjs-cli": "1.1.3",
        "@types/gm": "^1.25.4",
        "@types/lodash": "^4.17.16",
        "@types/node": "^20.17.46",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3"
    }
}
