{
    "name": "rustplusplus",
    "version": "1.30.1",
    "description": "A NodeJS Discord Bot that uses the rustplus.js library to utilize the power of the Rust+ Companion App with additional Quality-of-Life features.",
    "main": "index.ts",
    "scripts": {
        "start": "node dist/index.js",
        "build": "tsc",
        "test": "tsc --noEmit",
        "dev:tsc": "tsc -w",
        "dev:node": "node --watch dist/index.js",
        "dev": "concurrently -n \"tsc,node\" -c \"yellow.bold,green.bold\" \"npm run dev:tsc\" \"npm run dev:node\"",
        "format": "biome format --write"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/rust-sense/bot.git"
    },
    "author": "jamezrin",
    "bugs": {
        "url": "https://github.com/rust-sense/bot/issues"
    },
    "homepage": "https://github.com/rust-sense/bot",
    "dependencies": {
        "@discordjs/builders": "^1.11.2",
        "@discordjs/opus": "^0.9.0",
        "@discordjs/rest": "^2.5.1",
        "@discordjs/voice": "^0.18.0",
        "@formatjs/intl": "^2.10.4",
        "@liamcottle/push-receiver": "^0.0.4",
        "@liamcottle/rustplus.js": "git+https://github.com/alexemanuelol/rustplus.js.git#089cfd3db1b04709911948bce669273139c6a124",
        "axios": "^1.5.0",
        "colors": "^1.4.0",
        "discord-api-types": "^0.38.15",
        "discord.js": "^14.21.0",
        "ffmpeg-static": "^5.2.0",
        "gm": "^1.25.0",
        "intl-messageformat": "^10.5.14",
        "jimp": "^0.22.10",
        "lodash": "^4.17.21",
        "sodium-native": "^4.0.4",
        "translate": "^3.0.0",
        "ts-node": "^10.9.1",
        "winston": "^3.10.0"
    },
    "resolutions": {
        "jpeg-js": "0.4.4",
        "protobufjs": "7.2.6"
    },
    "devDependencies": {
        "@biomejs/biome": "1.8.3",
        "@types/node": "^20.14.10",
        "concurrently": "^9.1.2",
        "typescript": "^5.2.2"
    }
}
