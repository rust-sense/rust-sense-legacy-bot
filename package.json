{
    "name": "rust-sense",
    "version": "1.30.1",
    "description": "A NodeJS Discord Bot that uses the rustplus.js library to utilize the power of the Rust+ Companion App with additional Quality-of-Life features.",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "proto:gen": "buf generate src/lib/fcm/proto && buf generate --template buf.rustplus.gen.yaml src/lib/rustplus",
        "build": "pnpm run proto:gen && tsc",
        "test": "pnpm run proto:gen && tsc --noEmit",
        "dev": "pnpm run proto:gen && tsx watch src/index.ts",
        "format": "biome format --write",
        "lint": "biome lint"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/rust-sense/bot.git"
    },
    "author": "jamezrin",
    "bugs": {
        "url": "https://github.com/rust-sense/bot/issues"
    },
    "homepage": "https://github.com/rust-sense/bot",
    "dependencies": {
        "@bufbuild/protobuf": "^2.5.2",
        "@discordjs/builders": "^1.14.1",
        "@discordjs/rest": "^2.6.1",
        "@discordjs/voice": "^0.19.2",
        "@formatjs/intl": "^4.1.8",
        "awilix": "^13.0.3",
        "axios": "^1.15.2",
        "colors": "^1.4.0",
        "discord-api-types": "^0.38.47",
        "discord.js": "^14.26.3",
        "ffmpeg-static": "^5.3.0",
        "gm": "^1.25.1",
        "intl-messageformat": "^11.2.3",
        "http_ece": "^1.2.0",
        "jimp": "^1.6.1",
        "lodash": "^4.18.1",
        "sodium-native": "^5.1.0",
        "translate": "^3.0.1",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "ws": "^8.18.0"
    },
    "resolutions": {
        "jpeg-js": "0.4.4"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.14",
        "@bufbuild/buf": "^1.51.0",
        "@bufbuild/protoc-gen-es": "^2.5.2",
        "@types/ws": "^8.5.14",
        "@types/gm": "^1.25.4",
        "@types/lodash": "^4.17.16",
        "@types/node": "^24.0.0",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3"
    }
}
